# =============================================================================
# IBM watsonx.ai Credentials
# =============================================================================
# Your IBM Cloud API Key — obtain from https://cloud.ibm.com/iam/apikeys
WATSONX_API_KEY=your_api_key_here

# Your watsonx.ai Project ID — find in your watsonx.ai project settings
WATSONX_PROJECT_ID=your_project_id_here

# watsonx.ai API endpoint URL (region-specific)
# US South (Dallas):  https://us-south.ml.cloud.ibm.com
# EU DE (Frankfurt):  https://eu-de.ml.cloud.ibm.com
# EU GB (London):     https://eu-gb.ml.cloud.ibm.com
# AP North (Tokyo):   https://jp-tok.ml.cloud.ibm.com
WATSONX_URL=your_watsonx_url_here

# =============================================================================
# IBM Granite Model Configuration
# =============================================================================
# Recommended models (use whichever is available in your watsonx.ai project):
#   ibm/granite-4-h-small             — Granite 4, latest generation (default)
#   ibm/granite-3-1-8b-instruct       — Granite 3.1 8B instruct
#   ibm/granite-8b-code-instruct      — code-focused tasks
WATSONX_MODEL_ID=ibm/granite-4-h-small

# =============================================================================
# Flask Application Settings
# =============================================================================
# Secret key for Flask sessions — replace with a strong random string
FLASK_SECRET_KEY=your_flask_secret_key_change_in_production

# Flask environment: development | production
FLASK_ENV=development

# Port to run the Flask server on
FLASK_PORT=5000

# Enable Flask debug mode: true | false (set false in production)
FLASK_DEBUG=true
