__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ── Virtual Environments ──────────────────────────────────────────────────────
.venv/
venv/
ENV/
env/
ENV*/

# ── IDEs, Editors, & Workspaces ───────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Operating System Junk ─────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
.AppleDouble
.LSOverride

# ── Logs & Databases ──────────────────────────────────────────────────────────
*.log
logs/
*.db
*.sqlite
*.sqlite3

# ── Temporary & Generated Output Files ─────────────────────────────────────────
tmp/
temp/
*.pdf
output/
dist/

# ── Testing & Code Quality Cache ──────────────────────────────────────────────
.pytest_cache/
.tox/
.coverage
.cache/
